<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Planificador de Guardias 2026</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .day-cell { transition: all 0.1s ease; cursor: pointer; user-select: none; position: relative; }
        .day-empty { background-color: #ffffff; border: 1px solid #e2e8f0; }
        .day-user1 { background-color: #3b82f6; color: white; border: 1px solid #2563eb; }
        .day-user2 { background-color: #10b981; color: white; border: 1px solid #059669; }
        .day-renegotiate { background-color: #fbbf24; color: #92400e; border: 1px solid #d97706; }
        
        .note-indicator { position: absolute; top: 2px; right: 2px; width: 6px; height: 6px; background-color: #ef4444; border-radius: 50%; }
        .note-btn { position: absolute; bottom: 2px; right: 2px; font-size: 10px; opacity: 0; transition: opacity 0.2s; background: rgba(255,255,255,0.95); padding: 1px 4px; border-radius: 4px; color: #1e293b; box-shadow: 0 1px 2px rgba(0,0,0,0.1); }
        .day-cell:hover .note-btn { opacity: 1; }

        @media print {
            .no-print { display: none !important; }
            body { background: white; padding: 0; }
            .calendar-card { box-shadow: none !important; border: 1px solid #eee !important; break-inside: avoid; }
        }
    </style>
</head>
<body class="bg-slate-100 min-h-screen p-2 md:p-8 font-sans text-slate-900">

    <div class="max-w-7xl mx-auto">
        <header class="bg-white p-4 md:p-6 rounded-2xl shadow-sm mb-4 border-b-2 border-slate-200">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                    <h1 class="text-2xl md:text-3xl font-bold text-slate-800 flex items-center gap-3">
                        📅 Planificación de Guardias 2026
                    </h1>
                    <p class="text-slate-500 mt-1 italic text-xs md:text-sm">Sistema de sincronización por enlace (Sin servidor)</p>
                </div>
                
                <div class="flex flex-wrap gap-2 no-print">
                    <button onclick="generarEnlace()" class="bg-indigo-600 text-white px-5 py-2 rounded-lg hover:bg-indigo-700 transition flex items-center gap-2 font-bold shadow-md">
                        🔗 Generar Enlace para Compartir
                    </button>
                    <button onclick="window.print()" class="bg-slate-800 text-white px-4 py-2 rounded-lg hover:bg-slate-700 transition flex items-center gap-2 font-medium">
                        📄 PDF
                    </button>
                </div>
            </div>

            <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-3">
                <div class="flex items-center justify-between bg-blue-50 p-3 rounded-xl border border-blue-100">
                    <div class="flex items-center gap-2 w-full">
                        <div class="w-3 h-3 bg-blue-500 rounded-full shrink-0"></div>
                        <input type="text" id="name1" value="ANGEL GASPAR BENITEZ" onchange="guardarLocal()" class="bg-transparent font-bold text-blue-900 outline-none w-full uppercase text-xs border-b border-transparent focus:border-blue-400">
                    </div>
                    <div class="text-blue-800 font-bold text-lg ml-2"><span id="count1">0</span></div>
                </div>

                <div class="flex items-center justify-between bg-emerald-50 p-3 rounded-xl border border-emerald-100">
                    <div class="flex items-center gap-2 w-full">
                        <div class="w-3 h-3 bg-emerald-500 rounded-full shrink-0"></div>
                        <input type="text" id="name2" value="MAXIMILIANO AGUIRRE" onchange="guardarLocal()" class="bg-transparent font-bold text-emerald-900 outline-none w-full uppercase text-xs border-b border-transparent focus:border-emerald-400">
                    </div>
                    <div class="text-emerald-800 font-bold text-lg ml-2"><span id="count2">0</span></div>
                </div>

                <div class="flex items-center justify-between bg-amber-50 p-3 rounded-xl border border-amber-100">
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 bg-amber-400 rounded-full"></div>
                        <span class="font-bold text-amber-900 text-xs uppercase">Renegociar</span>
                    </div>
                    <div class="text-amber-800 font-bold text-lg ml-2"><span id="count3">0</span></div>
                </div>
            </div>
        </header>

        <div id="linkPanel" class="hidden no-print bg-emerald-50 border-2 border-emerald-200 p-4 rounded-xl mb-6 shadow-inner animate-pulse">
            <h4 class="text-emerald-800 font-bold text-sm mb-2">✅ ¡Listo! Envía este enlace a Maximiliano:</h4>
            <div class="flex flex-col md:flex-row gap-2">
                <input type="text" id="finalLinkInput" readonly class="w-full bg-white p-2 rounded border border-emerald-300 font-mono text-xs text-emerald-900">
                <button onclick="copiarEnlace()" class="bg-emerald-600 text-white px-6 py-2 rounded font-bold hover:bg-emerald-700 whitespace-nowrap shadow">Copiar Link</button>
            </div>
            <p class="text-emerald-600 text-[11px] mt-2 font-medium">Cuando él abra este enlace, verá tu calendario exacto. Si él hace cambios, deberá generar un nuevo enlace y devolvértelo.</p>
        </div>

        <div id="calendarGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 md:gap-6"></div>

        <!-- Note Modal -->
        <div id="noteModal" class="fixed inset-0 bg-slate-900/60 hidden z-50 flex items-center justify-center p-4 no-print backdrop-blur-sm">
            <div class="bg-white rounded-2xl p-6 w-full max-w-sm shadow-2xl">
                <h3 class="text-lg font-bold text-slate-800 mb-2">Nota: <span id="modalDateDisplay" class="text-indigo-600"></span></h3>
                <textarea id="noteInput" class="w-full h-32 p-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none mb-4 text-slate-700 resize-none" placeholder="Escribe un comentario..."></textarea>
                <div class="flex justify-end gap-2">
                    <button onclick="cerrarNota()" class="px-4 py-2 text-slate-500 hover:bg-slate-100 rounded-lg">Cancelar</button>
                    <button onclick="guardarNota()" class="px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 shadow-md">Guardar</button>
                </div>
            </div>
        </div>

        <div id="toast" class="fixed bottom-5 right-5 hidden bg-slate-800 text-white px-6 py-3 rounded-xl shadow-2xl z-50"></div>
    </div>

    <script>
        let guards = {};
        let notes = {};
        let names = { n1: "ANGEL GASPAR BENITEZ", n2: "MAXIMILIANO AGUIRRE" };
        const year = 2026;
        let activeNoteKey = null;

        function init() {
            // Revisar si hay datos en el enlace (URL)
            const urlParams = new URLSearchParams(window.location.search);
            const dataCodificada = urlParams.get('d');
            
            if (dataCodificada) {
                try {
                    // Decodificar los datos del enlace
                    const dataDecodificada = JSON.parse(decodeURIComponent(atob(dataCodificada)));
                    guards = dataDecodificada.g || {};
                    notes = dataDecodificada.nt || {};
                    names.n1 = dataDecodificada.n1 || "ANGEL GASPAR BENITEZ";
                    names.n2 = dataDecodificada.n2 || "MAXIMILIANO AGUIRRE";
                    
                    // Limpiar la URL de arriba para que no quede larguísima
                    window.history.replaceState({}, '', window.location.href.split('?')[0]);
                    
                    guardarLocal();
                    mostrarNotificacion("📥 Datos sincronizados desde el enlace.");
                } catch (e) {
                    console.error("Enlace corrupto", e);
                    cargarLocal();
                }
            } else {
                cargarLocal();
            }

            document.getElementById('name1').value = names.n1;
            document.getElementById('name2').value = names.n2;
            renderizarCalendario();
        }

        function renderizarCalendario() {
            const grid = document.getElementById('calendarGrid');
            grid.innerHTML = '';
            const meses = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
            meses.forEach((nombre, m) => { grid.appendChild(crearMes(m, nombre)); });
            actualizarContadores();
        }

        function crearMes(m, nombre) {
            const card = document.createElement('div');
            card.className = "calendar-card bg-white p-4 rounded-xl shadow-sm border border-slate-200";
            card.innerHTML = `<h3 class="font-bold text-slate-700 mb-3 text-center border-b pb-2 uppercase tracking-widest text-[10px]">${nombre}</h3>`;
            const daysGrid = document.createElement('div');
            daysGrid.className = "grid grid-cols-7 gap-1 text-[10px]";
            ["L", "M", "X", "J", "V", "S", "D"].forEach(d => {
                const h = document.createElement('div'); h.className = "text-center font-bold text-slate-300 mb-1"; h.innerText = d;
                daysGrid.appendChild(h);
            });
            const first = new Date(year, m, 1).getDay();
            const offset = first === 0 ? 6 : first - 1;
            const daysInMonth = new Date(year, m + 1, 0).getDate();
            
            for (let i = 0; i < offset; i++) daysGrid.appendChild(document.createElement('div'));
            
            for (let d = 1; d <= daysInMonth; d++) {
                const key = `${year}-${m+1}-${d}`;
                const dayEl = document.createElement('div');
                dayEl.innerHTML = `<span class="relative z-10">${d}</span>`;
                
                if (notes[key]) {
                    const dot = document.createElement('div'); dot.className = "note-indicator"; dayEl.appendChild(dot);
                }
                
                const btn = document.createElement('div');
                btn.className = "note-btn no-print"; btn.innerText = "📝";
                btn.onclick = (e) => { e.stopPropagation(); abrirNota(key); };
                dayEl.appendChild(btn);
                
                aplicarEstilo(dayEl, guards[key] || 0);
                
                dayEl.onclick = () => {
                    guards[key] = ((guards[key] || 0) + 1) % 4;
                    if (guards[key] === 0) delete guards[key];
                    aplicarEstilo(dayEl, guards[key] || 0);
                    guardarLocal();
                    document.getElementById('linkPanel').classList.add('hidden'); // Ocultar link viejo
                };
                daysGrid.appendChild(dayEl);
            }
            card.appendChild(daysGrid);
            return card;
        }

        function aplicarEstilo(el, status) {
            el.className = "day-cell h-9 md:h-10 flex items-center justify-center rounded-lg font-bold ";
            if (status === 1) el.classList.add('day-user1');
            else if (status === 2) el.classList.add('day-user2');
            else if (status === 3) el.classList.add('day-renegotiate');
            else el.classList.add('day-empty');
        }

        function actualizarContadores() {
            let c1 = 0, c2 = 0, c3 = 0;
            Object.values(guards).forEach(v => { if (v === 1) c1++; if (v === 2) c2++; if (v === 3) c3++; });
            document.getElementById('count1').innerText = c1;
            document.getElementById('count2').innerText = c2;
            document.getElementById('count3').innerText = c3;
        }

        function abrirNota(key) {
            activeNoteKey = key;
            document.getElementById('modalDateDisplay').innerText = key;
            document.getElementById('noteInput').value = notes[key] || "";
            document.getElementById('noteModal').classList.remove('hidden');
        }
        
        function cerrarNota() { document.getElementById('noteModal').classList.add('hidden'); activeNoteKey = null; }

        function guardarNota() {
            const val = document.getElementById('noteInput').value.trim();
            if (val) notes[activeNoteKey] = val; else delete notes[activeNoteKey];
            guardarLocal(); 
            renderizarCalendario(); 
            cerrarNota();
            document.getElementById('linkPanel').classList.add('hidden');
        }

        function guardarLocal() {
            names.n1 = document.getElementById('name1').value;
            names.n2 = document.getElementById('name2').value;
            localStorage.setItem('guardias_2026_db', JSON.stringify({ guards, names, notes }));
            actualizarContadores();
        }

        function cargarLocal() {
            const saved = localStorage.getItem('guardias_2026_db');
            if (saved) {
                try {
                    const data = JSON.parse(saved);
                    guards = data.guards || {};
                    names = data.names || names;
                    notes = data.notes || {};
                } catch(e) {}
            }
        }

        // LA MAGIA: Genera un enlace con los datos incrustados
        function generarEnlace() {
            const dataAExportar = { g: guards, nt: notes, n1: names.n1, n2: names.n2 };
            // Comprimir a texto base64
            const dataCodificada = btoa(encodeURIComponent(JSON.stringify(dataAExportar)));
            
            // Obtener la URL limpia
            const baseUrl = window.location.href.split('?')[0];
            const urlFinal = baseUrl + '?d=' + dataCodificada;

            document.getElementById('finalLinkInput').value = urlFinal;
            document.getElementById('linkPanel').classList.remove('hidden');
            
            copiarEnlace();
        }

        function copiarEnlace() {
            const copyText = document.getElementById("finalLinkInput");
            copyText.select();
            document.execCommand("copy");
            mostrarNotificacion("¡Enlace copiado! Pégalo en WhatsApp.");
        }

        function mostrarNotificacion(msg) {
            const t = document.getElementById('toast');
            t.innerText = msg; t.classList.remove('hidden');
            setTimeout(() => t.classList.add('hidden'), 3500);
        }

        window.onload = init;
    </script>
</body>
</html>